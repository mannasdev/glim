{
  "name": "@glim-sdk/next",
  "version": "0.2.0",
  "description": "A drop-in guidance companion for Next.js apps — a little glowing character that answers your users' questions and flies to point at the exact UI it's talking about. Powered by Claude.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannasdev/glim.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/mannasdev/glim#readme",
  "bugs": "https://github.com/mannasdev/glim/issues",
  "keywords": [
    "nextjs",
    "react",
    "onboarding",
    "product-tour",
    "ai",
    "claude",
    "anthropic",
    "guide",
    "copilot",
    "user-assistance"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "tsup && vitest run"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^25.0.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
